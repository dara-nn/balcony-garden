{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "balcony-garden",
  "compatibility_date": "2026-05-22",
  "main": "src/index.js",
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "PHOTOS",
      "id": "2896ac496bc54f5e8aba011f54a850b1"
    }
  ]
}
